# Required (Runtime)
# Supabase (public keys used by client; set in Vercel Preview/Production)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (server-only service role - keep secret)
SUPABASE_SERVICE_ROLE_KEY=

# AI provider keys - at least one is required for AI analysis endpoints
# (set one or more of these depending on provider)
GROQ_API_KEY=
OPENAI_API_KEY=
AI_GATEWAY_API_KEY=

# Internal protection token for internal job endpoints (optional for public deployments)
INTERNAL_JOBS_TOKEN=

# TruthSerum (optional external scoring service)
TRUTH_SERUM_URL=
TRUTH_SERUM_TOKEN=
TRUTH_SERUM_TIMEOUT_MS=500

# Engine / Safety configuration (optional runtime tuning)
FEATURE_ROB_ENGINE=0
SAFETY_MAX_SPREAD_PCT=1.0
SAFETY_MIN_UNDERLYING_VOLUME_24H=100000
SAFETY_MIN_OPTION_VOLUME_24H=100
SAFETY_MIN_OPTION_OI=200
SAFETY_MAX_SIZE_CAP_PCT=5
SAFETY_MAX_NOTIONAL_USD=25000
SAFETY_EARNINGS_BLACKOUT_BEFORE_DAYS=2
SAFETY_EARNINGS_BLACKOUT_AFTER_DAYS=1
SAFETY_MAX_SLIPPAGE_PCT=0.5

# Institutional validation defaults (optional)
MIN_EMPIRICAL_TRADES=30
MIN_DETERMINISM_COVERAGE=1
MAX_REPLAY_MISMATCH_RATE=0
MAX_ROLLING_DRAWDOWN=0.2
MAX_RUIN_PROBABILITY=0.05

# Replay / enforcement thresholds (optional)
REPLAY_COVERAGE_THRESHOLD=0
REPLAY_MISMATCH_THRESHOLD=1

# Other (dev / runtime)
ENGINE_VERSION=
RUN_REGIME_HARNESS=0
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=
PORT=8787
NODE_ENV=development
